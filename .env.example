# SentimentEdge Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to Git. It is already listed in .gitignore.

# NewsAPI
NEWSAPI_KEY=your_newsapi_key_here

# DagsHub and MLflow
DAGSHUB_USERNAME=your_dagshub_username
DAGSHUB_TOKEN=your_dagshub_access_token
MLFLOW_TRACKING_URI=https://dagshub.com/your_username/sentimentedge.mlflow

# Neon PostgreSQL
DATABASE_URL=postgresql://user:password@ep-something.us-east-2.aws.neon.tech/sentimentedge?sslmode=require

# Cloudflare R2
R2_ENDPOINT_URL=https://your_account_id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# HuggingFace
HF_TOKEN=your_huggingface_write_token

# Oracle VM IPs (filled in after VM creation)
KAFKA_BROKER=your_kafka_vm_ip:9092
KAFKA_VM_IP=your_kafka_vm_ip
REDIS_HOST=your_redis_vm_ip
REDIS_VM_IP=your_redis_vm_ip
